<Page x:Class="MtgStatsApp.Views.DecksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MtgStatsApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="900"
      Title="My Decks Management">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="My Decks" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                       Text="Manage reference information for your commander decks. Real names only." Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Decks List Panel -->
            <ui:Card Grid.Column="0" Margin="0,0,16,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="All Decks" Grid.Row="0" Margin="4,4,4,12"/>
                    
                    <ListView x:Name="LstDecks" Grid.Row="1" SelectionChanged="OnDeckSelectionChanged"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding DeckName}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding MoxfieldUrl}" FontSize="12" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </ui:Card>

            <!-- Deck Detail/Edit Panel -->
            <ui:Card Grid.Column="1" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <TextBlock x:Name="TxtFormHeader" FontSize="20" FontWeight="SemiBold" Text="Create New Deck" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Deck Name" />
                            <ui:TextBox x:Name="TxtDeckName" PlaceholderText="e.g. Atraxa, Praetors' Voice" />
                            <!-- Rule Indicator -->
                            <Border CornerRadius="4" Background="#26E81123" BorderThickness="1" BorderBrush="#80E81123" Padding="8,6" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ui:SymbolIcon Symbol="Warning16" Foreground="#FFE81123" VerticalAlignment="Center"/>
                                    <TextBlock Text="Real name only. Do NOT include Moxfield prefixes like [S2], [Active] or [Testing]." 
                                               FontSize="12" Foreground="#FFE81123" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Moxfield URL" />
                            <ui:TextBox x:Name="TxtMoxfieldUrl" PlaceholderText="https://www.moxfield.com/decks/..." />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Notes" />
                            <ui:TextBox x:Name="TxtNotes" AcceptsReturn="True" Height="100" VerticalScrollBarVisibility="Auto" 
                                        PlaceholderText="Theme, special combos, proxy references, or bracket details..." />
                        </StackPanel>

                        <ui:InfoBar x:Name="InfoBarDeck" IsOpen="False" Title="Message" Message="" Severity="Success"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <ui:Button x:Name="BtnDelete" Grid.Column="0" Content="Delete" Appearance="Danger" 
                                       Visibility="Collapsed" Click="OnDeleteClick"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <ui:Button Content="Clear / New" Click="OnClearClick"/>
                                <ui:Button Content="Save Deck" Appearance="Primary" Click="OnSaveClick" Width="120"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </ui:Card>
        </Grid>
    </Grid>
</Page>

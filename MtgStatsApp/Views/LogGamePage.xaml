<Page x:Class="MtgStatsApp.Views.LogGamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MtgStatsApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Log Game">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <ui:TextBlock FontTypo="Title" Text="Log a Game" />
                <ui:TextBlock FontTypo="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                              Text="Log a new game quickly. Target: log in under 10 seconds." Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                <ui:TextBlock Text="Game Type:" VerticalAlignment="Center" FontTypo="BodyStrong"/>
                <ui:ToggleSwitch x:Name="SwGameType" OffContent="Live Game" OnContent="Horde Game" Checked="OnGameTypeChanged" Unchecked="OnGameTypeChanged" IsChecked="False"/>
            </StackPanel>
        </Grid>

        <!-- Main Form Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <Grid.ColumnDefinition Width="1*"/>
                    <Grid.ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Common Metrics -->
                <ui:Card Grid.Column="0" Margin="0,0,16,0" Padding="20">
                    <StackPanel Spacing="12">
                        <ui:TextBlock FontTypo="Subtitle" Text="Core Metrics" />
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Date picker -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                <ui:TextBlock Text="Date" />
                                <DatePicker x:Name="DpDate" SelectedDateChanged="OnFormInputChanged"/>
                            </StackPanel>
                            
                            <!-- Deck selector -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                                <ui:TextBlock Text="My Deck" />
                                <ComboBox x:Name="CbDecks" DisplayMemberPath="DeckName" SelectedValuePath="DeckId" SelectionChanged="OnFormInputChanged" TabIndex="1"/>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Mulligan Count -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                <ui:TextBlock Text="Mulligans" />
                                <ComboBox x:Name="CbMulligans" SelectedIndex="0" TabIndex="2">
                                    <ComboBoxItem Content="0" />
                                    <ComboBoxItem Content="1" />
                                    <ComboBoxItem Content="2" />
                                    <ComboBoxItem Content="3" />
                                    <ComboBoxItem Content="4" />
                                    <ComboBoxItem Content="5" />
                                    <ComboBoxItem Content="6" />
                                    <ComboBoxItem Content="7" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Lands Drawn Opening -->
                            <StackPanel Grid.Column="1" Margin="8,0,8,0" Spacing="4">
                                <ui:TextBlock Text="Lands in Hand" />
                                <ComboBox x:Name="CbLandsDrawn" SelectedIndex="3" TabIndex="3">
                                    <ComboBoxItem Content="0" />
                                    <ComboBoxItem Content="1" />
                                    <ComboBoxItem Content="2" />
                                    <ComboBoxItem Content="3" />
                                    <ComboBoxItem Content="4" />
                                    <ComboBoxItem Content="5" />
                                    <ComboBoxItem Content="6" />
                                    <ComboBoxItem Content="7" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Commander Cast Turn -->
                            <StackPanel Grid.Column="2" Margin="8,0,0,0" Spacing="4">
                                <ui:TextBlock Text="Cmd Cast Turn" />
                                <ui:TextBox x:Name="TxtCommanderCastTurn" PlaceholderText="e.g. 4" TabIndex="4" PreviewTextInput="NumberValidation"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <Grid.ColumnDefinition Width="1*"/>
                                <Grid.ColumnDefinition Width="1*"/>
                                <Grid.ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Commander Recast Count -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                <ui:TextBlock Text="Cmd Recasts" />
                                <ui:TextBox x:Name="TxtCommanderRecastCount" PlaceholderText="0" TabIndex="5" PreviewTextInput="NumberValidation"/>
                            </StackPanel>

                            <!-- Turn Count -->
                            <StackPanel Grid.Column="1" Margin="8,0,8,0" Spacing="4">
                                <ui:TextBlock Text="Total Turns" />
                                <ui:TextBox x:Name="TxtTurnCount" PlaceholderText="e.g. 8" TabIndex="6" PreviewTextInput="NumberValidation"/>
                            </StackPanel>

                            <!-- Recovered checkbox -->
                            <StackPanel Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Bottom">
                                <CheckBox x:Name="ChkRecoveredFromWipe" Content="Recovered from Wipe" TabIndex="9" Margin="0,0,0,4"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <Grid.ColumnDefinition Width="1*"/>
                                <Grid.ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- My Wipe Count -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                <ui:TextBlock Text="Wipes I Cast" />
                                <ui:TextBox x:Name="TxtMyWipeCount" PlaceholderText="0" TabIndex="7" PreviewTextInput="NumberValidation"/>
                            </StackPanel>

                            <!-- Opponent Wipe Count -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                                <ui:TextBlock Text="Wipes Faced" />
                                <ui:TextBox x:Name="TxtOpponentWipeCount" PlaceholderText="0" TabIndex="8" PreviewTextInput="NumberValidation" TextChanged="OnOpponentWipesChanged"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <Grid.ColumnDefinition Width="1*"/>
                                <Grid.ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Salt Prior -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                <Grid>
                                    <ui:TextBlock Text="Salt Level Prior" HorizontalAlignment="Left"/>
                                    <ui:TextBlock x:Name="TxtSaltPriorVal" Text="3" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="SlSaltPrior" Minimum="1" Maximum="10" Value="3" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="OnSaltPriorChanged"/>
                            </StackPanel>

                            <!-- Salt Observed -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                                <Grid>
                                    <ui:TextBlock Text="Salt Level Observed" HorizontalAlignment="Left"/>
                                    <ui:TextBlock x:Name="TxtSaltObservedVal" Text="3" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="SlSaltObserved" Minimum="1" Maximum="10" Value="3" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="OnSaltObservedChanged"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <ui:TextBlock Text="Notes" />
                            <ui:TextBox x:Name="TxtNotes" AcceptsReturn="True" Height="70" VerticalScrollBarVisibility="Auto" PlaceholderText="Qualitative notes, combos, tables, optional rules..." TabIndex="10"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- Right Column: Mode Specific Settings -->
                <Grid Grid.Column="1">
                    
                    <!-- Live Game Config (Visible when SwGameType is UNCHECKED/FALSE) -->
                    <ui:Card x:Name="CardLiveConfig" Padding="20" Margin="16,0,0,0" Visibility="Visible">
                        <StackPanel Spacing="16">
                            <ui:TextBlock FontTypo="Subtitle" Text="Live Game Info" />
                            <ui:TextBlock Text="Standard Commander rules apply. All parameters tracked in the general panel on the left are calibrated to your bracket target. Turn count and recasts will measure opponent pressure." 
                                          FontTypo="Body" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            <Border CornerRadius="4" Background="#1a007acc" BorderThickness="1" BorderBrush="#80007acc" Padding="12" Margin="0,16,0,0">
                                <StackPanel Spacing="8">
                                    <ui:TextBlock Text="Live Logging Mode" FontTypo="BodyStrong" Foreground="#FF007ACC"/>
                                    <ui:TextBlock Text="• Press Tab to navigate fields.&#x0a;• Keep Turn Count accurate for bracket calibration.&#x0a;• Press Save Game to log immediately." 
                                                  FontTypo="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ui:Card>

                    <!-- Horde Game Config (Visible when SwGameType is CHECKED/TRUE) -->
                    <ui:Card x:Name="CardHordeConfig" Padding="20" Margin="16,0,0,0" Visibility="Collapsed">
                        <StackPanel Spacing="12">
                            <ui:TextBlock FontTypo="Subtitle" Text="Horde Game Parameters" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ui:ColumnDefinition Width="2*"/>
                                    <ui:ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Horde Deck Selector -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                    <ui:TextBlock Text="Horde Adversary Deck" />
                                    <ComboBox x:Name="CbHordeDecks" DisplayMemberPath="DeckName" SelectedValuePath="HordeDeckId" TabIndex="20"/>
                                </StackPanel>

                                <!-- Game Result (Win/Loss) -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                                    <ui:TextBlock Text="Result" />
                                    <ComboBox x:Name="CbHordeResult" SelectedIndex="0" TabIndex="21">
                                        <ComboBoxItem Content="Win" Tag="win" />
                                        <ComboBoxItem Content="Loss" Tag="loss" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Separator Margin="0,4"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ui:ColumnDefinition Width="1*"/>
                                    <ui:ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Players Slider -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                    <Grid>
                                        <ui:TextBlock Text="Co-op Players" HorizontalAlignment="Left"/>
                                        <ui:TextBlock x:Name="TxtHordePlayersVal" Text="1" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                                    <Slider x:Name="SlHordePlayers" Minimum="1" Maximum="4" Value="1" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="OnHordePlayersChanged" TabIndex="22"/>
                                </StackPanel>

                                <!-- Survivor Life -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                                    <ui:TextBlock Text="Survivor Starting Life" />
                                    <ui:TextBox x:Name="TxtSurvivorLife" PlaceholderText="e.g. 20" TabIndex="23" PreviewTextInput="NumberValidation"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ui:ColumnDefinition Width="1*"/>
                                    <ui:ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Draws Per Turn -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                    <ui:TextBlock Text="Horde Draws Per Turn" />
                                    <ComboBox x:Name="CbDrawsPerTurn" SelectedIndex="0" TabIndex="24">
                                        <ComboBoxItem Content="1" />
                                        <ComboBoxItem Content="2" />
                                        <ComboBoxItem Content="3" />
                                        <ComboBoxItem Content="4" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Token Multiplier -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                                    <ui:TextBlock Text="Horde Token Multiplier" />
                                    <ComboBox x:Name="CbTokenMultiplier" SelectedIndex="0" TabIndex="25">
                                        <ComboBoxItem Content="1x" Tag="1"/>
                                        <ComboBoxItem Content="2x" Tag="2"/>
                                        <ComboBoxItem Content="3x" Tag="3"/>
                                        <ComboBoxItem Content="4x" Tag="4"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ui:ColumnDefinition Width="1*"/>
                                    <ui:ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Starting Deck Size Pct -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                                    <ui:TextBlock Text="Starting Deck Size %" />
                                    <ComboBox x:Name="CbDeckSizePct" SelectedIndex="4" TabIndex="26">
                                        <ComboBoxItem Content="20%" Tag="20" />
                                        <ComboBoxItem Content="40%" Tag="40" />
                                        <ComboBoxItem Content="60%" Tag="60" />
                                        <ComboBoxItem Content="80%" Tag="80" />
                                        <ComboBoxItem Content="100%" Tag="100" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Milestone Pct -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="4">
                                    <ui:TextBlock Text="Milestone % Target" />
                                    <ComboBox x:Name="CbMilestonePct" SelectedIndex="0" TabIndex="27">
                                        <ComboBoxItem Content="0%" Tag="0" />
                                        <ComboBoxItem Content="25%" Tag="25" />
                                        <ComboBoxItem Content="50%" Tag="50" />
                                        <ComboBoxItem Content="75%" Tag="75" />
                                        <ComboBoxItem Content="100%" Tag="100" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Co-op commanders -->
                            <StackPanel Spacing="4">
                                <ui:TextBlock Text="Co-op Partner Commanders (comma-separated)" />
                                <ui:TextBox x:Name="TxtCoOpCommanders" PlaceholderText="e.g. Karrthus, Tyrant of Jund; Urza, Lord High Artificer" TabIndex="28"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Save Button Footer -->
        <Grid Grid.Row="1" VerticalAlignment="Bottom" Height="60" Margin="0,16,0,0">
            <ui:InfoBar x:Name="InfoBarLog" IsOpen="False" Title="Message" Message="" Severity="Success" Width="600" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ui:Button x:Name="BtnSaveGame" Content="Save Game (Ctrl+S)" Appearance="Primary" Icon="{ui:SymbolIcon Save24}" 
                       Click="OnSaveGameClick" Width="180" HorizontalAlignment="Right" VerticalAlignment="Center" Height="40" TabIndex="30"/>
        </Grid>
    </Grid>
</Page>

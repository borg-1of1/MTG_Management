<Page x:Class="MtgStatsApp.Views.HordeDecksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MtgStatsApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="900"
      Title="Horde Decks Management">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Horde Decks" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                       Text="Manage Reference Decks used for Horde Magic (Official or Community/Custom configurations)." Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Horde Decks List Panel -->
            <ui:Card Grid.Column="0" Margin="0,0,16,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Horde Decks" Grid.Row="0" Margin="4,4,4,12"/>
                    
                    <ListView x:Name="LstHordeDecks" Grid.Row="1" SelectionChanged="OnHordeDeckSelectionChanged"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding DeckName}" FontWeight="SemiBold" FontSize="14" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <Border CornerRadius="4" Padding="4,2" Margin="0,0,8,0" Background="{DynamicResource AccentTextFillColorPrimaryBrush}" Visibility="{Binding IsOfficial, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                            <TextBlock Text="OFFICIAL" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Text="{Binding SourceUrl}" FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </ui:Card>

            <!-- Horde Deck Detail/Edit Panel -->
            <ui:Card Grid.Column="1" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <TextBlock x:Name="TxtFormHeader" FontSize="20" FontWeight="SemiBold" Text="Create New Horde Deck" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Deck Name" />
                            <ui:TextBox x:Name="TxtDeckName" PlaceholderText="e.g. Zombie Horde, Zombie Draft" />
                        </StackPanel>

                        <CheckBox x:Name="ChkIsOfficial" Content="Official against-the-horde.com deck" Margin="0,4,0,4"/>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Source URL" />
                            <ui:TextBox x:Name="TxtSourceUrl" PlaceholderText="https://against-the-horde.com/deck/..." />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Notes" />
                            <ui:TextBox x:Name="TxtNotes" AcceptsReturn="True" Height="100" VerticalScrollBarVisibility="Auto" 
                                        PlaceholderText="Horde deck composition, customized card swaps, rules..." />
                        </StackPanel>

                        <ui:InfoBar x:Name="InfoBarDeck" IsOpen="False" Title="Message" Message="" Severity="Success"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <ui:Button x:Name="BtnDelete" Grid.Column="0" Content="Delete" Appearance="Danger" 
                                       Visibility="Collapsed" Click="OnDeleteClick"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <ui:Button Content="Clear / New" Click="OnClearClick"/>
                                <ui:Button Content="Save Deck" Appearance="Primary" Click="OnSaveClick" Width="120"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </ui:Card>
        </Grid>
    </Grid>
</Page>

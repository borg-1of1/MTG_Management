<Page x:Class="MtgStatsApp.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MtgStatsApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Dashboard">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <ui:TextBlock FontTypo="Title" Text="Dashboard" />
            <ui:TextBlock FontTypo="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                          Text="At-a-glance performance metrics and game history summary." Margin="0,4,0,0" />
        </StackPanel>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">
                
                <!-- Stat Cards Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Games -->
                    <ui:Card Grid.Column="0" Margin="0,0,12,0" Padding="16">
                        <StackPanel Spacing="8">
                            <ui:TextBlock FontTypo="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="TOTAL GAMES LOGGED" />
                            <ui:TextBlock x:Name="TxtTotalGames" FontTypo="TitleLarge" Text="0" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        </StackPanel>
                    </ui:Card>

                    <!-- Live Games -->
                    <ui:Card Grid.Column="1" Margin="6,0,6,0" Padding="16">
                        <StackPanel Spacing="8">
                            <ui:TextBlock FontTypo="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="LIVE MATCHES" />
                            <ui:TextBlock x:Name="TxtLiveGames" FontTypo="TitleLarge" Text="0" />
                        </StackPanel>
                    </ui:Card>

                    <!-- Horde Games -->
                    <ui:Card Grid.Column="2" Margin="6,0,6,0" Padding="16">
                        <StackPanel Spacing="8">
                            <ui:TextBlock FontTypo="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="HORDE MATCHES" />
                            <ui:TextBlock x:Name="TxtHordeGames" FontTypo="TitleLarge" Text="0" />
                        </StackPanel>
                    </ui:Card>

                    <!-- Horde Win Rate -->
                    <ui:Card Grid.Column="3" Margin="12,0,0,0" Padding="16">
                        <StackPanel Spacing="8">
                            <ui:TextBlock FontTypo="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="HORDE WIN RATE" />
                            <ui:TextBlock x:Name="TxtHordeWinRate" FontTypo="TitleLarge" Text="0%" Foreground="#FF267F00" />
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <!-- Core Details Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Averages and calibration -->
                    <ui:Card Grid.Column="0" Margin="0,0,12,0" Padding="20">
                        <StackPanel Spacing="16">
                            <ui:TextBlock FontTypo="Subtitle" Text="Gameplay Metrology" />
                            
                            <!-- Average turn count -->
                            <Grid Margin="0,4">
                                <ui:TextBlock Text="Average Turn Length" FontTypo="Body" VerticalAlignment="Center"/>
                                <ui:TextBlock x:Name="TxtAvgTurns" Text="N/A" FontTypo="BodyStrong" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <!-- Average Salt observed -->
                            <Grid Margin="0,4">
                                <ui:TextBlock Text="Average Salt Observed (1-10)" FontTypo="Body" VerticalAlignment="Center"/>
                                <ui:TextBlock x:Name="TxtAvgSalt" Text="N/A" FontTypo="BodyStrong" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Board wipe frequency -->
                            <Grid Margin="0,4">
                                <ui:TextBlock Text="Average Wipes Faced / Game" FontTypo="Body" VerticalAlignment="Center"/>
                                <ui:TextBlock x:Name="TxtAvgWipesFaced" Text="N/A" FontTypo="BodyStrong" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Wipe recovery frequency -->
                            <Grid Margin="0,4">
                                <ui:TextBlock Text="Wipe Recovery Success Rate" FontTypo="Body" VerticalAlignment="Center"/>
                                <ui:TextBlock x:Name="TxtWipeRecoveryRate" Text="N/A" FontTypo="BodyStrong" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Right: Top Played Decks -->
                    <ui:Card Grid.Column="1" Margin="12,0,0,0" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <ui:TextBlock FontTypo="Subtitle" Text="Top Played Decks" Grid.Row="0" Margin="0,0,0,12"/>
                            
                            <ListView x:Name="LstTopDecks" Grid.Row="1" Background="Transparent" BorderThickness="0" Focusable="False">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBlock Text="{Binding DeckName}" FontTypo="BodyStrong" Grid.Column="0"/>
                                            <ui:TextBlock Text="{Binding PlayCount, StringFormat='{}{0} games'}" FontTypo="Body" Grid.Column="1" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </ui:Card>
                </Grid>
                
                <!-- Welcome/Get Started panel if empty -->
                <ui:Card x:Name="CardEmptyState" Padding="24" Visibility="Collapsed" Background="#0d007acc">
                    <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="24">
                        <ui:SymbolIcon Symbol="BookmarkMultiple24" Size="48" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        <ui:TextBlock Text="Welcome to MTG Stats Manager!" FontTypo="Subtitle" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <ui:TextBlock Text="Your database is currently empty. Head over to the 'Log a Game' section to record your first match." 
                                      FontTypo="Body" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
